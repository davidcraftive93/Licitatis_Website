# ============================================================================
# LICITATIS — configuración de Apache/LiteSpeed para el sitio estático (Hostinger)
# Este archivo se copia a out/ en el build y se sirve desde el directorio público.
# Ajusta las cabeceras con criterio de seguridad; ver docs/SECURITY.md.
# ============================================================================

# --- Forzar HTTPS (Hostinger gestiona el certificado SSL) -------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# --- Cabeceras de seguridad -------------------------------------------------
<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://*.hsforms.com https://*.hubspot.com https://*.hs-scripts.com https://*.hs-analytics.net https://*.hscollectedforms.net https://*.hs-banner.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.hsforms.com https://*.hubspot.com https://www.google-analytics.com; font-src 'self' data:; connect-src 'self' https://api.hsforms.com https://forms.hsforms.com https://*.hsforms.com https://*.hubspot.com https://*.hs-analytics.net https://www.google-analytics.com https://*.analytics.google.com; frame-src 'self' https://*.hsforms.com https://*.hubspot.com; manifest-src 'self'; upgrade-insecure-requests"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), browsing-topics=(), interest-cohort=()"
  Header always set X-DNS-Prefetch-Control "on"
  # No revelar el software del servidor si el hosting lo permite.
  Header unset X-Powered-By
</IfModule>

# --- Compresión -------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml application/manifest+json
</IfModule>

# --- Caché ------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # Recursos con hash (immutables): caché larga.
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML: sin caché agresiva para permitir despliegues.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# --- Tipos MIME de archivos sin extensión generados por Next ----------------
# La imagen Open Graph se exporta como archivo "opengraph-image" sin extensión;
# forzamos su Content-Type para que los rastreadores sociales la reconozcan.
<Files "opengraph-image">
  ForceType image/png
</Files>

# --- Páginas de error -------------------------------------------------------
ErrorDocument 404 /404.html

# --- Endurecimiento adicional ----------------------------------------------
# Evitar el listado de directorios.
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# Bloquear el acceso a archivos ocultos sensibles (por si acaso).
<FilesMatch "(^\.env|\.env\.|^\.git)">
  Require all denied
</FilesMatch>
