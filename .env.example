# ============================================================================
# Variables de entorno — LICITATIS Website (landing comercial)
# Copia este archivo a .env.local para desarrollo y NO subas .env.local a git.
# Ningún valor secreto debe incluirse en este archivo de ejemplo.
# ============================================================================

# --- URLs del sitio -------------------------------------------------------
# URL pública canónica del sitio. En local puede quedar vacío (usa el valor por
# defecto). En Vercel Preview conviene usar la URL de la preview; en Production,
# https://www.licitatis.es cuando el dominio esté conectado.
NEXT_PUBLIC_SITE_URL=

# URL de la aplicación privada (fuera de este proyecto/despliegue).
NEXT_PUBLIC_APP_URL=https://app.licitatis.es

# Correo de contacto que se muestra en la web (pendiente de confirmar).
NEXT_PUBLIC_CONTACT_EMAIL=

# --- HubSpot --------------------------------------------------------------
# Sitio ESTÁTICO: el formulario se envía desde el cliente a la Forms API pública.
# Portal ID y Form ID son identificadores PÚBLICOS (no secretos) y se incrustan en
# el build. Deben estar disponibles al compilar el artefacto que se despliega.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_ID=

# NO se usa un token privado en esta web estática. Si se necesitara una integración
# privada (CRM API), debe ir en un backend/servicio seguro independiente, NUNCA aquí:
#   HUBSPOT_PRIVATE_APP_TOKEN=  (no lo definas en este proyecto)

# --- Despliegue (Hostinger) -----------------------------------------------
# Los secretos de despliegue NO van aquí: se guardan en el GitHub Environment
# "production" (HOSTINGER_HOST, HOSTINGER_PORT, HOSTINGER_USERNAME,
# HOSTINGER_SSH_PRIVATE_KEY, HOSTINGER_DEPLOY_PATH). Ver docs/DEPLOYMENT.md.

# --- Analítica (opcional; desactivada por defecto) ------------------------
# Pon "true" para permitir cargar analítica tras el consentimiento del usuario.
NEXT_PUBLIC_ENABLE_ANALYTICS=false
# ID de medición de Google Analytics 4 (formato G-XXXXXXXXXX). Opcional.
NEXT_PUBLIC_GA_ID=
